    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
